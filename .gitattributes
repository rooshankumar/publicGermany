# Normalize line endings across the repo
# Default: treat all files as text and use LF in the repository
* text=auto eol=lf

# Mark common binary files to avoid EOL conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text eol=lf
*.ico binary
*.pdf binary
*.ttf binary
*.woff binary
*.woff2 binary

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Code files (explicitly LF)
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.lock text eol=lf

# Avoid normalizing lock binaries that some tools generate
*.lockb binary
